[global]
font = FiraCode Nerd Font
width = 320
height = 160
origin = top-right
offset = 20x20
padding = 15
horizontal_padding = 16
text_icon_padding = 8
frame_width = 2
corner_radius = 10
# Usando o Aqua/Blue para a borda geral (substituindo o Lavender)
frame_color = "#83a598"
separator_color = frame
transparency = 8
blur = true
shadow = yes
# Sombra ajustada para o fundo Dark 0 (Hard)
shadow_color = "#1d2021"
shadow_offset = 3x3
icon_theme = papirus
enable_recursive_icon_lookup = true
show_indicators = no
idle_threshold = 120
follow = keyboard
markup = full
format = "<b>%s</b>\n<span size='small'>%b</span>"
stack_duplicates = true
sticky_history = true
history_length = 20

[urgency_low]
# Background: Dark 2 | Foreground: Gray (Dark 4) | Frame: Dark 3
background = "#504945"
foreground = "#a89984"
frame_color = "#665c54"

[urgency_normal]
# Background: Dark 0 (Medium) | Foreground: Light 1 | Frame: Aqua
background = "#282828"
foreground = "#ebdbb2"
frame_color = "#83a598"

[urgency_critical]
# Background: Dark 0 (Hard) | Foreground: Bright Red | Frame: Bright Red
background = "#1d2021"
foreground = "#fb4934"
frame_color = "#fb4934"
