[global]
font = FiraCode Nerd Font
width = 320
height = 160
origin = top-right
offset = 20x20
padding = 15
horizontal_padding = 16
text_icon_padding = 8
frame_width = 2
corner_radius = 10
# Usando o azul Moon (#82aaff) para a borda geral
frame_color = "#82aaff"
separator_color = frame
transparency = 8
blur = true
shadow = yes
# Sombra ajustada para o fundo Moon
shadow_color = "#1b1d2b"
shadow_offset = 3x3
icon_theme = papirus
enable_recursive_icon_lookup = true
show_indicators = no
idle_threshold = 120
follow = keyboard
markup = full
format = "<b>%s</b>\n<span size='small'>%b</span>"
stack_duplicates = true
sticky_history = true
history_length = 20

[urgency_low]
background = "#1e2030"
foreground = "#828bb8"
frame_color = "#636da6"

[urgency_normal]
background = "#222436"
foreground = "#c8d3f5"
frame_color = "#82aaff"

[urgency_critical]
background = "#222436"
foreground = "#ff757f"
# Vermelho vibrante Moon para alertas críticos
frame_color = "#ff757f"
